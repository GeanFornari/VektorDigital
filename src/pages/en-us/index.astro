---
// Contém código gerado por IA
/**
 * Página principal em Português (Brasil)
 */
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import AppMockup from '../../components/AppMockup.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('hero.title')}>
	<Header />
	
	<main class="pt-32">
		<!-- Hero Section -->
		<section id="inicio" class="relative overflow-hidden px-6 pb-20 pt-10 md:pt-20">
			<!-- Background Glow Decorations -->
			<div class="absolute -top-24 -left-20 w-96 h-96 bg-accent/10 blur-[120px] rounded-full"></div>
			<div class="absolute top-[40%] -right-20 w-80 h-80 bg-accent/5 blur-[100px] rounded-full"></div>

			<div class="max-w-5xl mx-auto text-center relative z-10">
				<div class="inline-flex items-center gap-2 glass px-4 py-1.5 rounded-full text-xs font-semibold mb-8 text-accent border-accent/20">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
					</span>
					{t('hero.badge')}
				</div>
				
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1] text-gradient">
					{t('hero.title').split(',')[0]} <br class="hidden md:block"/> 
					<span class="text-accent">{t('hero.title').split(',')[1]}</span>
				</h1>
				
				<p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
					{t('hero.subtitle')}
				</p>

				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<button class="bg-accent text-background px-10 py-4 rounded-2xl font-bold text-lg hover:scale-105 transition-transform accent-glow">
						{t('hero.cta1')}
					</button>
					<button class="glass px-10 py-4 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all">
						{t('hero.cta2')}
					</button>
				</div>

                <!-- Hero Mockup -->
                <div class="mt-20 relative animate-float">
                    <div class="absolute -inset-10 bg-accent/10 blur-[100px] rounded-full"></div>
                    <img 
                        src="/images/hero-mockup.png" 
                        alt="KontrolSub App Dashboard" 
                        class="max-w-[320px] md:max-w-[400px] mx-auto rounded-[3rem] shadow-2xl relative z-10 border border-white/10"
                    />
                </div>
			</div>
		</section>

		<!-- Features Showcase -->
		<section id="funcionalidades" class="py-24 px-6 md:px-12 bg-white/[0.02]">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-bold mb-4">{t('features.title')}</h2>
					<p class="text-text-secondary">{t('features.subtitle')}</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <FeatureCard 
                        icon="🔔" 
                        title={t('feature1.title')} 
                        description={t('feature1.desc')}
                    />
                    <FeatureCard 
                        icon="📊" 
                        title={t('feature2.title')} 
                        description={t('feature2.desc')}
                    />
                    <FeatureCard 
                        icon="⚡" 
                        title={t('feature3.title')} 
                        description={t('feature3.desc')}
                    />
                </div>
			</div>
		</section>

        <!-- Product Showcase Section -->
        <section class="py-24 px-6 md:px-12">
            <div class="max-w-7xl mx-auto">
                <AppMockup 
                    src="/images/analytics-mockup.png" 
                    alt="Analytics Dashboard showing spending categories"
                    caption={t('product.caption')}
                    reverse={false}
                >
                    <h2 class="text-3xl md:text-5xl font-bold mb-6">{t('product.title')}</h2>
                    <p class="text-lg text-text-secondary leading-relaxed">
                        {t('product.desc')}
                    </p>
                    <ul class="space-y-4 mt-8">
                        <li class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
                            <span>{t('product.list1')}</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
                            <span>{t('product.list2')}</span>
                        </li>
                    </ul>
                </AppMockup>
            </div>
        </section>
	</main>

	<!-- Simple Footer with Lead Capture -->
	<footer id="contato" class="py-20 px-6 border-t border-white/10 mt-20 relative overflow-hidden">
        <div class="absolute -bottom-24 left-1/2 -translate-x-1/2 w-[80%] h-64 bg-accent/10 blur-[120px] rounded-full"></div>
        
		<div class="max-w-5xl mx-auto text-center relative z-10">
			<h2 class="text-3xl font-bold mb-4">{t('footer.newsletter.title')}</h2>
			<p class="text-text-secondary mb-10 max-w-xl mx-auto">{t('footer.newsletter.desc')}</p>
			
			<form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto mb-16 transition-all duration-500">
				<input 
					type="email" 
                    id="email-input"
					placeholder={t('footer.newsletter.placeholder')} 
					class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 focus:outline-none focus:border-accent/50 transition-all text-white"
					required
				/>
				<button type="submit" class="bg-accent text-background px-8 py-4 rounded-2xl font-bold hover:brightness-110 transition-all whitespace-nowrap flex items-center justify-center gap-2 group">
					<span>{t('footer.newsletter.button')}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="m9 18 6-6-6-6"/></svg>
				</button>
			</form>

            <div id="success-message" class="hidden max-w-lg mx-auto mb-16 animate-in fade-in zoom-in duration-500">
                <div class="glass p-6 rounded-2xl border-accent/20 flex flex-col items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-accent text-2xl">✨</div>
                    <div>
                        <h3 class="font-bold text-xl text-accent">{t('footer.newsletter.success.title')}</h3>
                        <p class="text-text-secondary">{t('footer.newsletter.success.desc')}</p>
                    </div>
                </div>
            </div>

            <script>
                const form = document.getElementById('newsletter-form');
                const successMsg = document.getElementById('success-message');
                const emailInput = document.getElementById('email-input');

                form?.addEventListener('submit', (e) => {
                    e.preventDefault();
                    
                    // Simulação de envio
                    const btn = form.querySelector('button');
                    if (btn) {
                        btn.disabled = true;
                        btn.innerHTML = '<span class="animate-pulse">Enviando...</span>';
                    }

                    setTimeout(() => {
                        form.classList.add('opacity-0', 'scale-95');
                        setTimeout(() => {
                            form.classList.add('hidden');
                            successMsg?.classList.remove('hidden');
                        }, 500);
                    }, 1500);
                });

                // Scroll Reveal Observer
                const observerOptions = {
                    threshold: 0.1
                };

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('reveal-visible');
                        }
                    });
                }, observerOptions);

                document.querySelectorAll('section').forEach(section => {
                    section.classList.add('reveal');
                    observer.observe(section);
                });
            </script>

			<div class="pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="flex items-center gap-2 opacity-80">
                    <div class="w-6 h-6 bg-accent rounded flex items-center justify-center font-bold text-background text-[10px]">V</div>
                    <span class="text-sm font-bold tracking-tight">Vektor Digital</span>
                </div>
				<p class="text-sm text-text-secondary">{t('footer.rights')}</p>
                <div class="flex gap-6">
                    <a href="#" class="text-sm text-text-secondary hover:text-accent">{t('footer.terms')}</a>
                    <a href="#" class="text-sm text-text-secondary hover:text-accent">{t('footer.privacy')}</a>
                </div>
			</div>
		</div>
	</footer>
</Layout>

<style>
	main {
		width: 100%;
		max-width: 100%;
		overflow-x: hidden;
	}

    .animate-float {
        animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
    }

    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    }

    .reveal-visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
