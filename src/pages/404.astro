---
// Contém código gerado por IA
// ignore_for_file: dangling_library_doc_comments
/**
 * 404.astro
 * 
 * Página de erro 404 customizada para o KontrolSub.
 * Redireciona usuários perdidos de volta para a segurança.
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Página Não Encontrada">
    <Header />
    <main class="min-h-screen flex items-center justify-center pt-20 px-6">
        <div class="max-w-2xl mx-auto text-center">
            <div class="relative mb-12">
                <h1 class="text-[12rem] md:text-[16rem] font-bold leading-none text-white opacity-5 select-none">404</h1>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-32 h-32 md:w-48 md:h-48 bg-accent/20 blur-[60px] rounded-full animate-pulse"></div>
                    <span class="text-6xl md:text-8xl relative z-10">🤔</span>
                </div>
            </div>
            
            <h2 class="text-3xl md:text-5xl font-bold mb-6 text-gradient">Ops! Onde estamos?</h2>
            <p class="text-lg md:text-xl text-text-secondary mb-12 max-w-lg mx-auto">
                Parece que você se aventurou por uma rota que ainda não mapeamos. Não se preocupe, o KontrolSub te ajuda a voltar para o caminho certo.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="/pt/" class="px-8 py-4 bg-accent text-background font-bold rounded-2xl hover:scale-105 transition-transform shadow-lg shadow-accent/20">
                    Voltar para o Início
                </a>
                <a href="https://vektordigital.com.br" class="px-8 py-4 glass text-white font-bold rounded-2xl hover:bg-white/10 transition-all border border-white/10">
                    Ir para Vektor Digital
                </a>
            </div>
        </div>
    </main>
    <Footer />
</Layout>

<style>
    .text-gradient {
        background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.7) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>
