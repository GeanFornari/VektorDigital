---
// Contém código gerado por IA
// IMPORTANTE: Esta página deve ser mantida em sincronia total com src/pages/[lang]/index.astro
/**
 * Página principal dinâmica (i18n)
 */
import { languages } from '../../../i18n/ui';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import AppMockup from '../../../components/AppMockup.astro';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---

<Layout title={t('hero.title')}>
	<Header />
	
	<main class="pt-32">
		<!-- Hero Section -->
		<section id="inicio" class="relative overflow-hidden px-6 pb-20 pt-10 md:pt-20">
			<!-- Background Glow Decorations -->
			<div class="absolute -top-24 -left-20 w-96 h-96 bg-accent/10 blur-[120px] rounded-full"></div>
			<div class="absolute top-[40%] -right-20 w-80 h-80 bg-accent/5 blur-[100px] rounded-full"></div>

			<div class="max-w-5xl mx-auto text-center relative z-10">
				<div class="inline-flex items-center gap-2 glass px-4 py-1.5 rounded-full text-xs font-semibold mb-8 text-accent border-accent/20">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
					</span>
					{t('hero.badge')}
				</div>
				
				<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1] text-gradient">
					{t('hero.title').split(',')[0]} <br class="hidden md:block"/> 
					<span class="text-accent">{t('hero.title').split(',')[1]}</span>
				</h1>
				
				<p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
					{t('hero.subtitle')}
				</p>

				<div class="flex flex-wrap gap-4 justify-center items-center">
					<a href="#" class="transition-transform hover:scale-105 active:scale-95">
						<img src="/images/Download_on_the_App_Store_Badge.svg.png" alt="Download on the App Store" class="h-12 md:h-14 w-auto" />
					</a>
					<a href="#" class="transition-transform hover:scale-105 active:scale-95">
						<img src="/images/get-it-on-google-play-badge.png" alt="Get it on Google Play" class="h-12 md:h-14 w-auto" />
					</a>
				</div>

                <!-- Hero Mockup -->
                <div class="mt-20 relative animate-float">
                    <div class="absolute -inset-10 bg-accent/10 blur-[100px] rounded-full"></div>
                    <img 
                        src="/images/hero-mockup.png" 
                        alt={t('hero.mockup_alt')} 
                        class="max-w-[320px] md:max-w-[400px] mx-auto rounded-[3rem] shadow-2xl relative z-10 border border-white/10"
                    />
                </div>
			</div>
		</section>

		<!-- Features Showcase -->
		<section id="funcionalidades" class="py-24 px-6 md:px-12 bg-white/[0.02]">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-bold mb-4">{t('features.title')}</h2>
					<p class="text-text-secondary">{t('features.subtitle')}</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <FeatureCard 
                        icon="🔔" 
                        title={t('feature1.title')} 
                        description={t('feature1.desc')}
                    />
                    <FeatureCard 
                        icon="📊" 
                        title={t('feature2.title')} 
                        description={t('feature2.desc')}
                    />
                    <FeatureCard 
                        icon="⚡" 
                        title={t('feature3.title')} 
                        description={t('feature3.desc')}
                    />
                </div>
			</div>
		</section>

        <!-- Product Showcase Section -->
        <section class="py-24 px-6 md:px-12">
            <div class="max-w-7xl mx-auto">
                <AppMockup 
                    src="/images/analytics-mockup.png" 
                    alt={t('product.mockup_alt')}
                    caption={t('product.caption')}
                    reverse={false}
                >
                    <h2 class="text-3xl md:text-5xl font-bold mb-6">{t('product.title')}</h2>
                    <p class="text-lg text-text-secondary leading-relaxed">
                        {t('product.desc')}
                    </p>
                    <ul class="space-y-4 mt-8">
                        <li class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
                            <span>{t('product.list1')}</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded-full bg-accent/20 flex items-center justify-center text-accent">✓</div>
                            <span>{t('product.list2')}</span>
                        </li>
                    </ul>
                </AppMockup>
            </div>
        </section>
	</main>

	<Footer />
</Layout>
