---
/**
 * Contém código gerado por IA
 */
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 py-4 px-6 md:px-12 transition-all duration-300">
    <div class="max-w-7xl mx-auto flex justify-between items-center glass p-4 md:px-8 rounded-2xl shadow-xl transition-all duration-300" id="header-container">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center font-bold text-background">K</div>
            <div class="flex flex-col">
                <span class="text-xl font-bold tracking-tight leading-none">Kontrol<span class="text-accent underline decoration-2 underline-offset-4">Sub</span></span>
                <span class="text-[10px] text-text-secondary font-medium tracking-widest uppercase mt-0.5 opacity-70">by Vektor Digital</span>
            </div>
        </div>
        
        <nav class="hidden md:flex items-center gap-8">
            <a href="#inicio" class="text-sm font-medium hover:text-accent transition-colors">Home</a>
            <a href="#funcionalidades" class="text-sm font-medium hover:text-accent transition-colors">Funcionalidades</a>
            <a href="#contato" class="text-sm font-medium hover:text-accent transition-colors">Contato</a>
        </nav>

        <div>
            <a href="#" class="bg-accent text-background px-6 py-2.5 rounded-xl font-bold text-sm hover:brightness-110 transition-all accent-glow whitespace-nowrap">
                Baixar App
            </a>
        </div>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const container = document.getElementById('header-container');
    
    window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
            header?.classList.add('py-2');
            container?.classList.add('bg-background/80', 'backdrop-blur-2xl');
            container?.classList.remove('bg-white/5');
        } else {
            header?.classList.remove('py-2');
            container?.classList.remove('bg-background/80', 'backdrop-blur-2xl');
            container?.classList.add('bg-white/5');
        }
    });
</script>
