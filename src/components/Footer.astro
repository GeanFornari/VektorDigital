---
// Contém código gerado por IA
/**
 * Componente de Rodapé com captura de leads (Newsletter) e i18n.
 * Inclui lógica de feedback do formulário sem textos hardcoded.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer id="contato" class="py-20 px-6 border-t border-white/10 mt-20 relative overflow-hidden">
    <div class="absolute -bottom-24 left-1/2 -translate-x-1/2 w-[80%] h-64 bg-accent/10 blur-[120px] rounded-full"></div>
    
    <div class="max-w-5xl mx-auto text-center relative z-10">
        <h2 class="text-3xl font-bold mb-4">{t('footer.newsletter.title')}</h2>
        <p class="text-text-secondary mb-10 max-w-xl mx-auto">{t('footer.newsletter.desc')}</p>
        
        <form 
            id="newsletter-form" 
            class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto mb-16 transition-all duration-500"
            data-sending={t('footer.newsletter.sending')}
        >
            <input 
                type="email" 
                id="email-input"
                placeholder={t('footer.newsletter.placeholder')} 
                class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 focus:outline-none focus:border-accent/50 transition-all text-white"
                required
            />
            <button type="submit" class="bg-accent text-background px-8 py-4 rounded-2xl font-bold hover:brightness-110 transition-all whitespace-nowrap flex items-center justify-center gap-2 group">
                <span>{t('footer.newsletter.button')}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="m9 18 6-6-6-6"/></svg>
            </button>
        </form>

        <div id="success-message" class="hidden max-w-lg mx-auto mb-16 animate-in fade-in zoom-in duration-500">
            <div class="glass p-6 rounded-2xl border-accent/20 flex flex-col items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-accent text-2xl">✨</div>
                <div>
                    <h3 class="font-bold text-xl text-accent">{t('footer.newsletter.success.title')}</h3>
                    <p class="text-text-secondary">{t('footer.newsletter.success.desc')}</p>
                </div>
            </div>
        </div>

        <div class="pt-10 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2 opacity-80">
                <div class="w-6 h-6 bg-accent rounded flex items-center justify-center font-bold text-background text-[10px]">V</div>
                <span class="text-sm font-bold tracking-tight">Vektor Digital</span>
            </div>
            <p class="text-sm text-text-secondary">{t('footer.rights')}</p>
            <div class="flex gap-6">
                <a href="#" class="text-sm text-text-secondary hover:text-accent">{t('footer.terms')}</a>
                <a href="#" class="text-sm text-text-secondary hover:text-accent">{t('footer.privacy')}</a>
            </div>
        </div>
    </div>
</footer>

<script>
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-message');
    const sendingText = form?.getAttribute('data-sending') || 'Enviando...';

    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const btn = form.querySelector('button');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-pulse">${sendingText}</span>`;
        }

        setTimeout(() => {
            form.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                form.classList.add('hidden');
                successMsg?.classList.remove('hidden');
            }, 500);
        }, 1500);
    });
</script>
